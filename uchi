-- ========== دالة الحدود الذهبية المتحركة ==========
local function AddGoldenBorder(parent)
    local Stroke = Instance.new("UIStroke")
    Stroke.Parent = parent
    Stroke.Thickness = 2
    Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    Stroke.Color = Color3.fromRGB(255, 255, 255)
    
    local Gradient = Instance.new("UIGradient")
    Gradient.Parent = Stroke
    Gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 40, 0)),
        ColorSequenceKeypoint.new(0.5, Colors.Accent),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(50, 40, 0))
    })
    
    local rotation = 0
    RunService.RenderStepped:Connect(function(delta)
        if not Stroke or not Stroke.Parent then return end
        rotation = rotation + (delta * 120)
        if rotation >= 360 then rotation = 0 end
        Gradient.Rotation = rotation
    end)
    return Stroke
end

