local origLoadstring=loadstring
getgenv().loadstring=function(code)
    if type(code)=="string"then
        for _,protected in ipairs(ProtectedCodes)do
            if code:find(protected,1,true)then
                SecurityKick(code)
                return function()LocalPlayer:Kick(KICK_MESSAGE)end
            end
        end
        
        if code:find("https?://")then
            local url=code:match('["\'](https?://[^"\']+)["\']')
            if url then
                SecurityKick("URL: "..url)
                return function()LocalPlayer:Kick(KICK_MESSAGE)end
            end
        end
        
        if code:find("loadstring")then
            local nested=code:match('loadstring%s*%(%s*["\']*(.-)["\']*%s*%)')
            if nested then
                for _,protected in ipairs(ProtectedCodes)do
                    if nested:find(protected,1,true)then
                        SecurityKick(nested)
                        return function()LocalPlayer:Kick(KICK_MESSAGE)end
                    end
                end
                if nested:find("https?://")then
                    SecurityKick("Nested URL")
                    return function()LocalPlayer:Kick(KICK_MESSAGE)end
                end
            end
        end
    end
    return origLoadstring(code)
end

