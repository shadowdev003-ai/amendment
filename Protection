local function ProtectTextElement(element)
    if not element or not element:IsA("GuiObject")then return end
    
    local originalText=element.Text or ""
    if #originalText<5 then return end
    
    for _,code in ipairs(ProtectedCodes)do
        if originalText:find(code,1,true)then
            element.Text=ScrambleText(originalText)
            element:GetPropertyChangedSignal("Text"):Connect(function()
                element.Text=ScrambleText(originalText)
            end)
            return
        end
    end
end

