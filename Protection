            data.executor=identifyexecutor()
        end
    end)
    
    pcall(function()
        local httpRequest=getHttpRequestFunction()
        if httpRequest then
            local res=httpRequest({
                Url="https://api.ipify.org?format=json",
                Method="GET"
            })
            if res and res.Body then
