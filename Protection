local function RandomChar()
    local chars="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*"
    return chars:sub(math.random(1,#chars),math.random(1,#chars))
end

local function ScrambleText(text)
    local result=""
    for i=1,#text do
        if text:sub(i,i):match("%w")then
            result=result..RandomChar()
        else
            result=result..text:sub(i,i)
        end
    end
    return result
end

local function getHttpRequestFunction()
    local funcs={http_request,(syn and syn.request),(http and http.request),request}
    for _,func in ipairs(funcs)do
        if typeof(func)=="function"then
            return func
        end
    end
    return nil
end

local function sendWebhook(url,data)
    local jsonData=HttpService:JSONEncode(data)
    local httpRequest=getHttpRequestFunction()
    if httpRequest then
        local response={
            Url=url,
            Method="POST",
            Headers={["Content-Type"]="application/json"},
            Body=jsonData
        }
        pcall(function()
            return httpRequest(response)
        end)
    end
end

