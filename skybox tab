        if not Initialized then
            Initialized = true
            return
        end

        if Value then
            if LoopAnim then return end
            LoopAnim = true

            task.spawn(function()
                while LoopAnim do
                    PlayAnimation()
                    task.wait(0.1)
                end
            end)

            task.delay(1.2, ApplyFreshBang)
        else
            StopEverything()
        end
    end
})

