local function safeInvokeServer(remote, args)
    local success, result = pcall(function()
        return remote:InvokeServer(unpack(args))
    end)
    return success, result
end

SkyboxTab:AddToggle({
    Name = "V6",
    Default = false,
    Callback = function(value)
        if value then
            local ReplicatedStorage = game:GetService("ReplicatedStorage")
            local ChangeCharacterBody = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ChangeCharacterBody")
            
            local args = {
                {
                    100839513065432
                }
            }
            
            safeInvokeServer(ChangeCharacterBody, args)
            
            local function missing(t, f, fallback)
                if type(f) == t then return f end
                return fallback 
            end
            
            cloneref = missing("function", cloneref, function(...) return ... end)
            
            local Services = setmetatable({}, {
                __index = function(_, name)
                    local success, result = pcall(function()
                        return cloneref(game:GetService(name))
                    end)
                    if success then
                        return result
                    end
                    return nil
                end
            })
            
            local Players = Services.Players
            local player = Players.LocalPlayer
            local character = player.Character or player.CharacterAdded:Wait()
            local humanoid = character:WaitForChild("Humanoid")
            
            v6Connection = player.CharacterAdded:Connect(function(newCharacter)
                local success, result = pcall(function()
                    character = newCharacter
                    humanoid = newCharacter:WaitForChild("Humanoid")
                    return true
                end)
                if not success then
                    warn("CharacterAdded error: " .. tostring(result))
                end
            end)
            
            local Settings = {
                ["Fade In"] = 0.1,
                ["Fade Out"] = 0.1,
                ["Weight"] = 1,
                ["Speed"] = 1,
                ["Time Position"] = 0,
                ["Loop"] = false
            }
            
            local function StopCurrentTrack()
                if v6Track then
                    local success = pcall(function()
                        v6Track:Stop(Settings["Fade Out"] or 0)
                    end)
                    v6Track = nil
                    return success
                end
                return false
            end
            
            local function LoadTrack(id)
                StopCurrentTrack()
                
                local animId
                local ok, result = pcall(function()
                    return game:GetObjects("rbxassetid://" .. tostring(id))
                end)
                
                if ok and result and #result > 0 then
                    local anim = result[1]
                    if anim:IsA("Animation") then
                        animId = anim.AnimationId
                    else
                        animId = "rbxassetid://" .. tostring(id)
                    end
                else
                    animId = "rbxassetid://" .. tostring(id)
                end
                
                local newAnim = Instance.new("Animation")
                newAnim.AnimationId = animId
                
                local loadSuccess, newTrack = pcall(function()
                    return humanoid:LoadAnimation(newAnim)
                end)
                
                if not loadSuccess or not newTrack then
                    warn("Failed to load animation: " .. tostring(newTrack))
                    return nil
                end
                
                newTrack.Priority = Enum.AnimationPriority.Action4
                
                local weight = Settings["Weight"]
                if weight == 0 then weight = 0.001 end
                
                local playSuccess = pcall(function()
                    newTrack:Play(Settings["Fade In"], weight, Settings["Speed"])
                end)
                
                if not playSuccess then
                    warn("Failed to play animation")
                    return nil
                end
                
                v6Track = newTrack
                
                pcall(function()
                    v6Track.TimePosition = math.clamp(Settings["Time Position"], 0, 1) * v6Track.Length
                end)
                
                return newTrack
            end
            
            local function ReloadOnRespawn()
                pcall(function()
                    player.CharacterAdded:Connect(function(newChar)
                        task.wait(0.5)
                        local success = pcall(function()
                            character = newChar
                            humanoid = newChar:WaitForChild("Humanoid", 5)
                            LoadTrack(70883871260184)
                        end)
                        if not success then
                            warn("Auto-reload failed")
                        end
                    end)
                end)
            end
            
            ReloadOnRespawn()
            
            local EmoteId = 70883871260184
            LoadTrack(EmoteId)
            
            spawn(function()
                while true do
                    task.wait(30)
                    pcall(function()
                        if not v6Track or not v6Track.IsPlaying then
                            LoadTrack(EmoteId)
                        end
                    end)
                end
            end)
        else
            StopV6()
        end
    end
})

