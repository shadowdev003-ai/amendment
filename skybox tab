local displayNames = {}
for _, v in ipairs(particleData) do
    table.insert(displayNames, v.display)
end

local selectedEffect = particleData[1]

SkyboxTab:AddDropdown({
    Name = "اختار المؤثر",
    Options = displayNames,
    Default = displayNames[1],
    Callback = function(value)
        for _, v in ipairs(particleData) do
            if v.display == value then
                selectedEffect = v
                break
            end
        end
    end
})

SkyboxTab:AddButton({
    Name = "تطبيق المؤثر",
    Callback = function()
        local cleanId = selectedEffect.asset:gsub("rbxassetid://", "")
        ApplyEmmiter:InvokeServer(cleanId, selectedEffect.server)
    end
})
