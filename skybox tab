                ["Fade Out"] = 0.1,
                ["Weight"] = 1,
                ["Speed"] = 1,
                ["Time Position"] = 0
            }

            local function LoadTrack(id)
                if v5Track then 
                    v5Track:Stop(0) 
                end

                local animId
                local ok, result = pcall(function()
                    return game:GetObjects("rbxassetid://" .. tostring(id))
                end)

                if ok and result and #result > 0 then
